{
  "manifest_version": 3,
  "name": "Claude++",
  "version": "0.1.0",
  "description": "A set of quality-of-life improvements for the claude.ai interface. Syncs your config across Chrome profiles, no backend.",
  "permissions": ["storage"],
  "host_permissions": ["https://claude.ai/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Claude++ Project Colors",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/inject-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": [
        "src/features/registry.js",
        "src/storage-sync.js",
        "src/core.js",
        "src/anchor.js",
        "src/features/project-colors.js",
        "src/features/create-project.js",
        "src/features/delete-guard.js",
        "src/features/tab-status.js",
        "src/features/asides.js",
        "src/features/bookmarks.js",
        "src/features/bookmarks-page.js",
        "src/data/emoji.js",
        "src/features/emoji-autocomplete.js",
        "src/features/scroll-nav.js",
        "src/features/draft-mode.js",
        "src/features/export-chat.js",
        "src/features/prompt-stash.js"
      ],
      "css": ["styles/content.css", "styles/asides.css", "styles/bookmarks.css", "styles/bookmarks-page.css", "styles/emoji-autocomplete.css", "styles/draft-mode.css", "styles/scroll-nav.css", "styles/export-chat.css", "styles/prompt-stash.css"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
